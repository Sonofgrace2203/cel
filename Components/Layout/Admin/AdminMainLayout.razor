@inherits LayoutComponentBase

<div class="page">
    <div class="scroll bg-primary">
        <div>
            <div class="bg-primary wx-3 pd-3 navheight slide-in-top wvl-5 pos-fix t-0 b-0 l-0 z-3"
                 style="display: @(hideMenu ? "none" : "block");">
                <div class="">
                    <div class="flex flex-end">
                        <button class="mdi mdi-cancel fsz-25 bg-transparent bd-none" @onclick="HideMenu"></button>
                    </div>
                    <a class="navbar-brand" href="">
                        <div class="flex flex-center">
                            <img class="wx-2 hx-2" src="icons/demoschlogo.png" alt="">
                        </div>
                    </a>
                    <div class="hx-7 scroll">
                        <AdminNavMenu />
                    </div>
                </div>
            </div>
        </div>

        <div class="wx-3 pd-3 navheight slide-in-left wvg-5"
             style="display: @(hideMenu ? "none" : "block");">
            <div class="">
                <a class="navbar-brand" href="">
                    <div class="flex flex-center">
                        <img class="wx-2 hx-2" src="icons/demoschlogo.png" alt="">
                    </div>
                </a>
                <AdminNavMenu />
            </div>
        </div>
    </div>

    <main class="navheight scroll bg-primary-01">
        <div class="top-row px-4 fsz-25 bg-primary-05 flex flex-spacebetween">
            <div>
                <button @onclick="ShowMenu" class="bg-transparent bd-none">
                    <i class="mdi mdi-menu fsz-35"></i>
                </button>
            </div>
            <div class="flex flex-spacebetween">
                <div class="pos-rel mgr-5 flex flex-center">
                    <i class="mdi mdi-bell"></i>
                    <div class="round wx-01 hx-01 bg-fatal pos-abs t-0"></div>
                </div>
                <p class="fsz-18 fw-bold">Mr John</p>
            </div>
        </div>

        <article class="content px-4 body-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool hideMenu = false;

    private void ShowMenu()
    {
        hideMenu = !hideMenu;
    }

    private void HideMenu()
    {
        hideMenu = true;
    }
}