@inject NavigationManager Nav


<div class="wx-3">
    <div class="top-row ps-3 navbar navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="">cel</a>
        </div>
    </div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="nav flex-column navadj">
            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="Dashboard" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu nav" aria-hidden="true"></span> Dashboard
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="students">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Students
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="teachers">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Teachers
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="parents">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Parents
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="classes">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Classes
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="subjects">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Subjects
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="approve">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Approves
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="results">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Results
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="reports">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Reports
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="users">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Users
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="profile">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Profile
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link navlink2" href="settings">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Settings
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <button class="nav-link navlink2" @onclick="ShowLogout">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Logout
                </button>
            </div>
        </nav>
    </div>
</div>

@if (ifLogout)
    {
        <div class="formpage">
            <DeleteModal ModalText="Confirm to Logout" ConfirmDelete="ConfirmLogout" ConfirmCancel="CancelLogout" />
        </div>
    }

@code {
    private bool ifLogout = false;

    private void ShowLogout()
    {
        ifLogout = !ifLogout;
    }

    private void ConfirmLogout()
    {
        ifLogout = true;
        Nav.NavigateTo("/");
    }

    private void CancelLogout()
    {
        ifLogout = false;
    }
}