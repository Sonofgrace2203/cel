<div class="form">
    <div class="flex flow pd-5 bg-white">
        <div class="flex align mgr-5 mgt-30">
            <div class="hx-2 wx-2 bg-gray round mgb-5">
            </div>
        </div>
        <div>
            <h2 class="pd">Create User</h2>
            <div class="grid col-2 bd pd">
                <div class="mg-3 miwx-2">
                    <div class="stack">
                        <label for="title" class="mg-2 fsz-15">Title</label>
                        <select name="" id="" class="mg-0 pd-5 bd corner-2 fsz-18">
                            <option value="">Select Title</option>
                            <option value="Mr">Mr</option>
                            <option value="Mrs">Mrs</option>
                            <option value="Master">Master</option>
                            <option value="Miss">Miss</option>
                        </select>
                    </div>
                    <p class="mg-2 cl-fatal">titleError</p>
                </div>
                <div class="mg-3 miwx-2">
                    <div class="stack">
                        <label for="name" class="mg-2 fsz-15">Name</label>
                        <input type="text" placeholder="Enter user's name..." class="mg-0 pd-5 bd corner-2 fsz-18" />
                    </div>
                    <p class="mg-2 cl-fatal">nameError</p>
                </div>
                <div class="mg-3 miwx-2">
                    <div class="stack">
                        <label for="email" class="mg-2 fsz-15">Email</label>
                        <input type="email" placeholder="Enter email address..." class="mg-0 pd-5 bd corner-2 fsz-18" />
                    </div>
                    <p class="mg-2 cl-fatal">idError</p>
                </div>
                <div class="mg-3 miwx-2">
                    <div class="stack">
                        <label for="role" class="mg-2 fsz-15">Role</label>
                        <select name="" id="" class="mg-0 pd-5 bd corner-2 fsz-18">
                            <option value="">Select Role</option>
                            <option value="JSS 1">Administrator</option>
                            <option value="JSS 2">Teacher</option>
                        </select>
                    </div>
                    <p class="mg-2 cl-fatal">roleError</p>
                </div>
            </div>

            <div class="wf fsz-20 mgt-10 flex flex-spacebetween flow">
                <div></div>
                <div>
                    <button @onclick="HandleCancel"
                    class="pdl-10 pdr-10 pdt-5 pdb-5 cl-primary bd-none bd bg-transparent bd-primary corner-2 fsz-20 mgb-5">Cancel</button>
                    <button class="pdl-10 pdr-10 pdt-5 pdb-5 cl-white bd-none bg-primary corner-2 fsz-20" @onclick="HandleAdd">Save
                        User</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

@code {
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnAdd { get; set; }

    private void HandleCancel()
    {
        OnCancel.InvokeAsync();
    }

    private void HandleAdd()
    {
        OnAdd.InvokeAsync();
    }
}