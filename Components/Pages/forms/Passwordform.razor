<div class="form">
    <div class="flex flow pd-5 bg-white">
        <div>
            <h2 class="pd">Change Password</h2>
            <div class="grid col-2 bd pd">
                <div class="mg-3 miwx-2">
                    <div class="stack">
                        <label for="oldpassword" class="mg-2 fsz-15">Old Password</label>
                        <input type="text" placeholder="Enter old password..." class="mg-0 pd-5 bd corner-2 fsz-18" />
                    </div>
                    <p class="mg-2 cl-fatal">oldpasswordError</p>
                </div>
                <div>
                    <div class="mg-3 miwx-2">
                        <div class="stack">
                            <label for="newpassword" class="mg-2 fsz-15">New Password</label>
                            <input type="text" placeholder="Enter new password..."
                                   class="mg-0 pd-5 bd corner-2 fsz-18" />
                        </div>
                        <p class="mg-2 cl-fatal">newpasswordError</p>
                    </div>
                    <div class="mg-3 miwx-2">
                        <div class="stack">
                            <label for="newpasswordconfirm" class="mg-2 fsz-15">Confirm New Password</label>
                            <input type="text" placeholder="Confirm new password..."
                                   class="mg-0 pd-5 bd corner-2 fsz-18" />
                        </div>
                        <p class="mg-2 cl-fatal">newpasswordConfirmError</p>
                    </div>
                </div>
            </div>

            <div class="wf fsz-20 mgt-10 flex flex-spacebetween flow">
                <div></div>
                <div>
                    <button @onclick="HandleCancel"
                            class="pdl-10 pdr-10 pdt-5 pdb-5 cl-primary bd-none bd bg-transparent bd-primary corner-2 fsz-20 mgb-5">Cancel</button>
                    <button class="pdl-10 pdr-10 pdt-5 pdb-5 cl-white bd-none bg-primary corner-2 fsz-20"
                            @onclick="HandleAdd">Save Password
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnAdd { get; set; }

    private void HandleCancel()
    {
        OnCancel.InvokeAsync();
    }

    private void HandleAdd()
    {
        OnAdd.InvokeAsync();
    }
}