        <div class="miwx-25">
            <StatCard Title="207" Subtitle="Approved Results" ImgPng="icons/success.svg" />
        </div>
        <div class="miwx-25">
            <StatCard Title="37" Subtitle="Declined Results" ImgPng="icons/decline.svg" />
        </div>
        <div class="miwx-25">
            <StatCard Title="132" Subtitle="Pending Approvals" ImgPng="icons/pending.svg" />
        </div>
    </div>

