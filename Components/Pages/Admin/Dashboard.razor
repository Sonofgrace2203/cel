@page "/"
@using Components.Layout.Admin
@using cel.Components.Pages.forms
@inject NavigationManager Nav

@layout AdminMainLayout

<div class="pd-5 bg-primary-01 main-container">
    <div class="mgb-10">
        <h2>Welcome, Administrator 🖐️</h2>
        <p>Here's what's happening in your school today.</p>
    </div>

    <div class="row responsive col-3 mgb-10">
        <div class="miwx-25">
            <StatCard Title="1234" Subtitle="Students" ImgPng="icons/seedoflife.svg" />
