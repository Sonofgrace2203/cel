                    <div class="mgb-3 mgt-3">
                        <p class="fsz-15 mg-0">🟢 Published</p>
                        <p class="bg-primary-01 pd text-center fw-bold fsz-25 mg-0">320</p>
                    </div>
                    <div class="mgb-3 mgt-3">
                        <p class="fsz-15 mg-0">🟡 Pending Approval</p>
                        <p class="bg-primary-01 pd text-center fw-bold fsz-25 mg-0">132</p>
                    </div>
                    <div class="mgb-3 mgt-3">
                        <p class="fsz-15 mg-0">🟣 Draft</p>
                        <p class="bg-primary-01 pd text-center fw-bold fsz-25 mg-0">210</p>
                    </div>
                    <div class="mgb-3 mgt-3">
                        <p class="fsz-15 mg-0">🔴 Rejected</p>
                        <p class="bg-primary-01 pd text-center fw-bold fsz-25 mg-0">18</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="miwx-15 pd">
            <h3>Quick Actions</h3>
            <hr />
            <div class="pd">
                <Button BtnIcon="➕" BtnText="Add Student" OnClick="ShowStudentForm" />
                <Button BtnIcon="➕" BtnText="Add Teacher" OnClick="ShowTeacherForm" />
                <Button BtnIcon="➕" BtnText="Create Class" OnClick="ShowClassForm" />
                <Button BtnIcon="➕" BtnText="Create Subject" OnClick="ShowSubjectForm" />
                <Button BtnIcon="➕" BtnText="Approve Results" OnClick="ApproveResults" />
            </div>
        </div>
    </div>
</div>

@if (showStudentForm)
{
    <div class="formpage">
        <Studentform OnCancel="CancelStudentForm" OnAdd="AddStudentForm" />
    </div>
}

@if (showTeacherForm)
{
    <div class="formpage">
        <Teacherform OnCancel="CancelTeacherForm" OnAdd="AddTeacherForm" />
    </div>
}

@if (showClassForm)
{
    <div class="formpage">
        <Classform OnCancel="CancelClassForm" OnAdd="AddClassForm" />
    </div>
}

@if (showSubjectForm)
{
    <div class="formpage">
        <Subjectform OnCancel="CancelSubjectForm" OnAdd="AddSubjectForm" />
    </div>
}

@code {
    private bool showStudentForm = false;
    private bool showTeacherForm = false;
    private bool showClassForm = false;
    private bool showSubjectForm = false;

    private void ShowStudentForm()
    {
        showStudentForm = !showStudentForm;
    }

    private void CancelStudentForm()
    {
        showStudentForm = false;
    }

    private void AddStudentForm()
    {
        showStudentForm = false;
    }

    private void ShowTeacherForm()
    {
        showTeacherForm = !showTeacherForm;
    }

    private void CancelTeacherForm()
    {
        showTeacherForm = false;
    }

    private void AddTeacherForm()
    {
        showTeacherForm = false;
    }

    private void ShowClassForm()
    {
        showClassForm = !showClassForm;
    }

    private void CancelClassForm()
    {
        showClassForm = false;
    }

    private void AddClassForm()
    {
        showClassForm = false;
    }

    private void ShowSubjectForm()
    {
        showSubjectForm = !showSubjectForm;
    }

    private void CancelSubjectForm()
    {
        showSubjectForm = false;
    }

    private void AddSubjectForm()
    {
        showSubjectForm = false;
    }

    private void ApproveResults()
    {
        Nav.NavigateTo("/approve");
    }
}