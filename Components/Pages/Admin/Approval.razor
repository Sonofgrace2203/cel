                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-content-save cl-success"
                                    @onclick="Edit"></button>
                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-cancel cl-fatal"
