                            <button @onclick="Delete"
                                    class="fsz-25 bg-transparent bd-none actbtn mdi mdi-eye cl-primary"></button>
                        </td> *@
                    </tr>
                    <tr>
                        <td class="pd-5 wx-3 bdb">JSS 1 A</td>
                        <td class="pd-5 wx-3 bdb">Mr Johnson</td>
                        <td class="pd-5 wx-3 bdb">35</td>
                        <td class="pd-5 wx-3 bdb">12 May 2026</td>
                        @* <td class="pd-5 wx-3">
                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-content-save cl-success"
                                    @onclick="Edit"></button>
                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-cancel cl-fatal"
                                    @onclick="Edit"></button>
                            <button @onclick="Delete"
                                    class="fsz-25 bg-transparent bd-none actbtn mdi mdi-eye cl-primary"></button>
                        </td> *@
                    </tr>
                    <tr>
                        <td class="pd-5 wx-3 bdb">JSS 1 A</td>
                        <td class="pd-5 wx-3 bdb">Mr Johnson</td>
                        <td class="pd-5 wx-3 bdb">35</td>
                        <td class="pd-5 wx-3 bdb">12 May 2026</td>
                        @* <td class="pd-5 wx-3">
                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-content-save cl-success"
                                    @onclick="Edit"></button>
                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-cancel cl-fatal"
                                    @onclick="Edit"></button>
                            <button @onclick="Delete"
                                    class="fsz-25 bg-transparent bd-none actbtn mdi mdi-eye cl-primary"></button>
                        </td> *@
                    </tr>
                    <tr>
                        <td class="pd-5 wx-3 bdb">JSS 1 A</td>
                        <td class="pd-5 wx-3 bdb">Mr Johnson</td>
                        <td class="pd-5 wx-3 bdb">35</td>
                        <td class="pd-5 wx-3 bdb">12 May 2026</td>
                        @* <td class="pd-5 wx-3">
                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-content-save cl-success"
                                    @onclick="ApproveResult"></button>
                            <button class="mgr-5 fsz-25 bg-transparent bd-none actbtn mdi mdi-cancel cl-fatal"
                                    @onclick="RejectResult"></button>
                            <button @onclick="ViewResults"
                                    class="fsz-25 bg-transparent bd-none actbtn mdi mdi-eye cl-primary"></button>
                        </td> *@
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="mgb-5">
    <Pagination />
</div>

@if (ifViewResult)
{
    <div class="formpage">
        <ViewResult OnCancel="CancelPreviewResult" />
    </div>
}

@if (ifApprove)
{
    <div class="formpage">
        <DeleteModal ModalText="Sure to approve result?" ConfirmDelete="ConfirmApprove" ConfirmCancel="CancelApprove" />
    </div>
}
@if (ifReject)
{
    <div class="formpage">
        <DeleteModal ModalText="Sure to reject result?" ConfirmDelete="ConfirmReject" ConfirmCancel="CancelReject" />
    </div>
}
@* @if (ifViewResult)
{
    <div class="formpage">
        <DeleteModal ModalText="Sure to delete student?" ConfirmDelete="Confirm" ConfirmCancel="Cancel" />
    </div>
} *@

@code {
    private bool ifApprove = false;
    private bool ifApproveConfirmed = true;
    private bool ifReject = false;
    private bool ifRejectConfirmed = true;
    private bool ifViewResult = false;

    private void IfApprove()
    {
        ifApprove = !ifApprove;
    }

    private void IfReject()
    {
        ifReject = !ifReject;
    }

    private void IfViewResult()
    {
        ifViewResult = !ifViewResult;
    }

    private void ConfirmApprove()
    {
        ifApprove = false;
        ifApproveConfirmed = true;
    }

    private void CancelApprove()
    {
        ifApprove = false;
    }

    private void ConfirmReject()
    {
        ifReject = false;
    }

    private void CancelReject()
    {
        ifReject = false;
    }

    private void CancelPreviewResult()
    {
        ifViewResult = false;
    }
}