            <DeleteModal ModalText="Sure to delete student?" ConfirmDelete="Delete" ConfirmCancel="CancelDelete" />
        </div>
    }

@code {
    private bool showModal = false;
    private bool ifDelete = false;

    private void ShowModal()
    {
        showModal = !showModal;
    }

    private void Cancel()
    {
        showModal = false;
    }

    private void AddParent()
    {
        showModal = false;
    }

    private void ShowDelete()
    {
        ifDelete = !ifDelete;
    }

    private void Delete()
    {
        ifDelete = false;
    }

    private void CancelDelete()
    {
        ifDelete = false;
    }
